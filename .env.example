# SEC EDGAR requires a descriptive User-Agent with contact info on every
# request. Set this to your app name + a real contact email.
# If unset, Prospect Scout logs a warning and uses a development fallback
# (best-effort; may be rate limited by SEC).
SEC_USER_AGENT="Prospect Scout your-email@example.com"

# Optional openFDA API key — not required, but improves rate limits when set.
# See https://open.fda.gov/apis/authentication/
FDA_API_KEY=

# Census Data API key for County Business Patterns market sizing (server-side only).
# Request a key at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Neon Postgres — persistent storage for organizations and discovery runs.
# Create a project at https://neon.tech and paste the pooled connection string.
# Uses @neondatabase/serverless + Drizzle ORM (not @vercel/postgres).
DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require

# Bearer token for POST /api/warehouse/import (production warehouse seeding).
WAREHOUSE_ADMIN_SECRET=
